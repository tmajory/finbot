# Configurações da Aplicação
APP_NAME="FinBot"
APP_VERSION="0.1.0"
DEBUG="True"
PORT="8000"
HOST="0.0.0.0"

# API Keys (obtenha gratuitamente)
GEMINI_API_KEY="sua_chave_gemini_aqui_obtenha_em: https://makersuite.google.com/app/apkey"
OPENROUTER_API_KEY="opcional_para_backup"


# Banco de Dados
DATABASE_URL="sqlite:///./finbot.db"
# Para PostgreSQL: "postgresql://usuario:senha@localhost/finbot"

# Segurança
SECRET_KEY="sua_chave_secreta_32_caracteres_aqui"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"

# Limites de Uso (para controle de custos)
MAX_DAILY_API_CALLS="100"
ENABLE_CACHE="True"
CACHE_TTL_SECONDS="3600"

# Configurações do Assistente
DEFAULT_CURRENCY="BRL"
TIMEZONE="America/Sao_Paulo"
